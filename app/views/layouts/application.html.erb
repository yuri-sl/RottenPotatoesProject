<!DOCTYPE html>
<html lang="en">
<head>
  <title>RottenPotatoes</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Open Sans', sans-serif; background-color: #1a1a1a; color: #f0f0f0; }

    .navbar-brand { font-family: 'Oswald', sans-serif; font-size: 1.9rem; color: #e63946 !important; letter-spacing: 1px; }
    .navbar { background-color: #111 !important; border-bottom: 3px solid #e63946; }
    .nav-link { color: #ccc !important; }
    .nav-link:hover { color: #e63946 !important; }

    h1, h2 { font-family: 'Oswald', sans-serif; }

    .card { background-color: #2d2d2d; border: 1px solid #444; border-radius: 8px; }
    .card-header { background-color: #222; border-bottom: 2px solid #e63946; font-family: 'Oswald', sans-serif; font-size: 1.2rem; color: #e63946; }

    .table { color: #f0f0f0; margin-bottom: 0; }
    .table thead th { background-color: #222; color: #e63946; font-family: 'Oswald', sans-serif; letter-spacing: 0.5px; border-color: #444; padding: 12px 16px; }
    .table tbody tr { border-color: #444; transition: background 0.15s; }
    .table tbody tr:hover { background-color: #3a3a3a; }
    .table td { vertical-align: middle; border-color: #444; padding: 10px 16px; }

    .badge-rating { font-size: 0.78rem; font-weight: 700; padding: 4px 9px; border-radius: 4px; letter-spacing: 0.3px; }
    .badge-G     { background-color: #2ecc71; color: #000; }
    .badge-PG    { background-color: #3498db; color: #fff; }
    .badge-PG-13 { background-color: #f39c12; color: #000; }
    .badge-R     { background-color: #e63946; color: #fff; }
    .badge-NC-17 { background-color: #8e44ad; color: #fff; }
    .badge-other { background-color: #666; color: #fff; }

    .btn-primary { background-color: #e63946; border-color: #e63946; }
    .btn-primary:hover { background-color: #c62b38; border-color: #c62b38; }
    .btn-outline-danger { color: #e63946; border-color: #e63946; }
    .btn-outline-danger:hover { background-color: #e63946; border-color: #e63946; }

    .btn-action { font-size: 0.78rem; padding: 3px 10px; border-radius: 4px; margin: 0 2px; }
    .btn-show   { background-color: #3498db; border: none; color: #fff; }
    .btn-show:hover { background-color: #2980b9; color: #fff; }
    .btn-edit   { background-color: #f39c12; border: none; color: #000; }
    .btn-edit:hover { background-color: #d68910; color: #000; }
    .btn-delete { background-color: #e63946; border: none; color: #fff; }
    .btn-delete:hover { background-color: #c62b38; color: #fff; }

    .form-control, .form-select { background-color: #333; border-color: #555; color: #f0f0f0; }
    .form-control:focus, .form-select:focus { background-color: #3a3a3a; border-color: #e63946; color: #f0f0f0; box-shadow: 0 0 0 0.2rem rgba(230,57,70,0.25); }
    select option { background-color: #333; }
    .form-label { color: #ccc; font-weight: 600; margin-bottom: 4px; }

    .movie-detail-card { background-color: #2d2d2d; border: 1px solid #444; border-left: 4px solid #e63946; border-radius: 8px; padding: 2rem; }
    .movie-title { font-family: 'Oswald', sans-serif; font-size: 2.4rem; color: #fff; margin-bottom: 0.25rem; }
    .movie-meta  { color: #aaa; font-size: 0.9rem; margin-bottom: 1rem; }
    .movie-description { color: #ddd; line-height: 1.8; }

    .alert-success { background-color: #1a3a2a; border-color: #2ecc71; color: #2ecc71; }
    .alert-danger  { background-color: #3a1a1a; border-color: #e63946; color: #f0a0a5; }

    footer { background-color: #111; border-top: 2px solid #222; color: #555; font-size: 0.85rem; }
    .movie-count-badge { background-color: #e63946; color: #fff; font-size: 0.75rem; padding: 2px 8px; border-radius: 12px; margin-left: 8px; vertical-align: middle; }

    .empty-state { text-align: center; padding: 4rem 2rem; color: #666; }
    .empty-state .empty-icon { font-size: 4rem; display: block; margin-bottom: 1rem; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container">
      <a class="navbar-brand" href="<%= root_path %>">🍅 RottenPotatoes</a>
      <div class="ms-auto">
        <%= link_to '+ Add Movie', new_movie_path, class: 'btn btn-outline-danger btn-sm' %>
      </div>
    </div>
  </nav>

  <main class="container my-4">
    <% if notice %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        🎬 <%= notice %>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
      </div>
    <% end %>
    <% if alert %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <%= alert %>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
      </div>
    <% end %>

    <%= yield %>
  </main>

  <footer class="py-3 mt-5">
    <div class="container text-center">
      🍅 RottenPotatoes &mdash; A movie tracking app
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
