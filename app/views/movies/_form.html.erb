<%= form_with model: movie, class: 'needs-validation' do |f| %>

  <% if movie.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= pluralize(movie.errors.count, "error") %> prevented this movie from being saved:</strong>
      <ul class="mb-0 mt-2">
        <% movie.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, class: 'form-label' %>
    <%= f.text_field :title, class: 'form-control', placeholder: 'Movie title' %>
  </div>

  <div class="mb-3">
    <%= f.label :rating, class: 'form-label' %>
    <%= f.select :rating, [['G — General Audiences', 'G'], ['PG — Parental Guidance', 'PG'], ['PG-13 — Parents Strongly Cautioned', 'PG-13'], ['R — Restricted', 'R'], ['NC-17 — Adults Only', 'NC-17']], { include_blank: '— Select a rating —' }, class: 'form-select' %>
  </div>

  <div class="mb-3">
    <%= f.label :release_date, class: 'form-label' %>
    <%= f.date_field :release_date, class: 'form-control', value: @movie.release_date&.strftime('%Y-%m-%d') %>
  </div>

  <div class="mb-4">
    <%= f.label :description, class: 'form-label' %>
    <%= f.text_area :description, rows: 5, class: 'form-control', placeholder: 'Brief description of the movie...' %>
  </div>

  <%= f.submit class: 'btn btn-primary px-4' %>

<% end %>
